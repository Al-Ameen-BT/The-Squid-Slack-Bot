# Slack Bot Tokens
# Get these from https://api.slack.com/apps
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_APP_TOKEN=xapp-your-app-token-here

# Channel where Squid crash/recovery alerts are posted (monitor only)
SLACK_ALERT_CHANNEL=your-alert-channel-id-here

# Channel where admin approval cards are posted (write commands)
SLACK_ADMIN_CHANNEL=your-admin-channel-id-here

# Comma-separated Slack User IDs of admins who can approve/reject requests
# Find user IDs in Slack: click user profile → More → Copy member ID
SLACK_ADMIN_USER_IDS=U111AAA,U222BBB,U333CCC

# Jira Integration
# Get API token from: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_EMAIL=squid-bot@your-org.com
JIRA_API_TOKEN=your-jira-api-token-here
JIRA_PROJECT_KEY=NET
