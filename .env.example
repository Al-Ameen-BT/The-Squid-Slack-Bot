# Slack Bot Tokens
# Get these from https://api.slack.com/apps
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_APP_TOKEN=xapp-your-app-token-here

# Dedicated log channel for ALL events:
#   - Every /allow /deny /extend /full-net /lock-net action (who did what, when)
#   - Squid crash & recovery alerts
# Set channel message retention to 15 days in: Slack Admin → Policies → Message Retention
SLACK_LOG_CHANNEL=your-log-channel-id-here
